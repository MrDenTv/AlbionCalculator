{
  "name": "albion-calculator",
  "version": "1.0.0",
  "description": "Albion Loot Calculator",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win nsis"
  },
  "build": {
    "appId": "com.albion.calculator",
    "productName": "AlbionCalculator",
    "win": {
      "target": "nsis",
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false
    },
    "publish": [
      {
        "provider": "github",
        "owner": "MrDenTv",
        "repo": "AlbionCalculator"
      }
    ]
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "tesseract.js": "^5.0.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  }
}
